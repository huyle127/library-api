{
  "name": "library-api",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && node -e \"const fs=require('fs');fs.cpSync('src/data','dist/data',{recursive:true});fs.cpSync('src/db/schema.sql','dist/db/schema.sql')\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:init": "ts-node src/db/migrate.ts",
    "db:seed": "ts-node src/db/seed.ts",
    "test:api": "ts-node src/test-api.ts",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:int": "jest tests/integration --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.22.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.43",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "description": "Library API on PostgreSQL via node-postgres (pg). Books, authors, categories.",
  "main": "index.js",
  "license": "ISC"
}
